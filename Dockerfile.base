ARG CUDA_BASE_IMAGE=nvidia/cuda:13.0.2-devel-ubuntu22.04
FROM ${CUDA_BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/workspace/hf \
    HF_HUB_CACHE=/workspace/hf/hub \
    TRANSFORMERS_CACHE=/workspace/hf \
    XDG_CACHE_HOME=/workspace/cache \
    VLLM_CACHE_ROOT=/workspace/vllm \
    TRITON_CACHE_DIR=/workspace/cache/triton \
    FLASHINFER_WORKSPACE_BASE=/workspace/cache/flashinfer \
    AWS_DEFAULT_REGION=auto \
    AWS_REGION=auto \
    VLLM_API_BASE=http://127.0.0.1:8000/v1 \
    CUDA_HOME=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:${PATH} \
    LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH} \
    CC=/usr/bin/gcc \
    CXX=/usr/bin/g++

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        g++ \
        gcc \
        git \
        make \
        ninja-build \
        pkg-config \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        tini \
    && mkdir -p \
        /app \
        /data/in \
        /data/out \
        /data/tmp \
        /workspace/cache \
        /workspace/cache/flashinfer \
        /workspace/cache/triton \
        /workspace/hf \
        /workspace/hf/hub \
        /workspace/vllm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY base/requirements.txt /tmp/chandra-vllm-base-requirements.txt

RUN python3 -m pip install --upgrade pip \
    && python3 -m pip install --no-cache-dir \
        -r /tmp/chandra-vllm-base-requirements.txt \
    && rm -f /tmp/chandra-vllm-base-requirements.txt

RUN echo "CUDA_BASE_IMAGE=${CUDA_BASE_IMAGE}" \
    && echo "PATH=${PATH}" \
    && echo "CUDA_HOME=${CUDA_HOME}" \
    && echo "LD_LIBRARY_PATH=${LD_LIBRARY_PATH}" \
    && echo "Checking CUDA installation..." \
    && ls -la /usr/local || true \
    && ls -la /usr/local/cuda || true \
    && ls -la /usr/local/cuda/bin || true \
    && echo "Checking required build tools..." \
    && command -v gcc \
    && command -v g++ \
    && command -v ninja \
    && command -v nvcc \
    && nvcc --version \
    && python3 - <<'PY'
import shutil

print("gcc:", shutil.which("gcc"))
print("g++:", shutil.which("g++"))
print("ninja:", shutil.which("ninja"))
print("nvcc:", shutil.which("nvcc"))
PY
