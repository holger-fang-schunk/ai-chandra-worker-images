# Required for worker mode
VLLM_MODEL=chandra-model-id-or-local-path
OCR_MODEL_NAME=chandra-model-id-or-local-path

# S3 job input/output/state
OCR_S3_BUCKET=my-ocr-bucket
OCR_S3_JOB_PREFIX=ocr-jobs/example-document
# Optional overrides. Defaults are <job>/input, <job>/output, <job>/state.
# OCR_S3_INPUT_PREFIX=ocr-jobs/example-document/input
# OCR_S3_OUTPUT_PREFIX=ocr-jobs/example-document/output
# OCR_S3_STATE_PREFIX=ocr-jobs/example-document/state
S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# AWS/S3 credentials should be injected securely by RunPod/template/secrets.
# Cloudflare R2 uses region auto. us-east-1 is accepted as an alias, but auto is clearer.
AWS_REGION=auto
AWS_DEFAULT_REGION=auto
AWS_ACCESS_KEY_ID=<set-via-runpod-secret>
AWS_SECRET_ACCESS_KEY=<set-via-runpod-secret>

# Model and cache data should live on a persistent RunPod network volume.
HF_HOME=/workspace/hf
HF_HUB_CACHE=/workspace/hf/hub
TRANSFORMERS_CACHE=/workspace/hf
XDG_CACHE_HOME=/workspace/cache
VLLM_CACHE_ROOT=/workspace/vllm
TRITON_CACHE_DIR=/workspace/cache/triton

# OCR tuning
OCR_PROMPT_TYPE=ocr_layout
OCR_MAX_SIDE=1400
OCR_MAX_NEW_TOKENS=1500
OCR_LAYOUT_JSON=true
OCR_NO_HTML=false
OCR_SAVE_RAW=false

# vLLM tuning
VLLM_GPU_MEMORY_UTILIZATION=0.80
VLLM_MAX_MODEL_LEN=4096
VLLM_MAX_NUM_BATCHED_TOKENS=1024
VLLM_TP=1
VLLM_STARTUP_TIMEOUT_SECONDS=900
